@model IReadOnlyList<EduChatbot.Models.ChatConversation>

@{
    var activeConversationId = ViewData["ActiveConversationId"] as int?;
    var conversations = Model ?? Array.Empty<EduChatbot.Models.ChatConversation>();
    var userName = User.Identity?.Name ?? "Student";
    var initial = string.IsNullOrWhiteSpace(userName) ? "S" : userName.Trim()[0].ToString().ToUpperInvariant();
    var today = DateTime.Today;
    var grouped = conversations
        .OrderByDescending(c => c.UpdatedAt)
        .GroupBy(c =>
        {
            var localDate = c.UpdatedAt.ToLocalTime().Date;
            if (localDate == today)
            {
                return "Today";
            }

            if (localDate == today.AddDays(-1))
            {
                return "Yesterday";
            }

            return "Previous";
        })
        .OrderBy(g => g.Key == "Today" ? 0 : g.Key == "Yesterday" ? 1 : 2);
}

<aside class="chat-sidebar" aria-label="Student chat navigation">
    <div class="chat-sidebar-brand">
        <a asp-controller="Chat" asp-action="Index" class="chat-brand-link" aria-label="EduChatbot">
            <span class="chat-brand-mark" aria-hidden="true">
                <svg viewBox="0 0 24 24" focusable="false">
                    <path d="M3.5 8.7 12 4.4l8.5 4.3-8.5 4.2-8.5-4.2Z" />
                    <path d="M6.5 10.4v4.4c1.7 1.3 3.5 1.9 5.5 1.9s3.8-.6 5.5-1.9v-4.4" />
                    <path d="M20.5 8.7v5.8" />
                </svg>
            </span>
            <span>EduChatbot</span>
        </a>
        <button class="chat-sidebar-toggle" type="button" aria-label="Collapse sidebar">
            <span aria-hidden="true">&laquo;</span>
        </button>
    </div>

    <nav class="chat-primary-nav" aria-label="Chat actions">
        <a asp-controller="Chat" asp-action="Index" class="chat-nav-action active">
            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                <path d="M4 20h4.2L19.4 8.8a2 2 0 0 0 0-2.8L18 4.6a2 2 0 0 0-2.8 0L4 15.8V20Z" />
                <path d="m13.8 6 4.2 4.2" />
            </svg>
            <span>New chat</span>
        </a>
        <a asp-controller="Chat" asp-action="Index" class="chat-nav-action">
            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                <circle cx="11" cy="11" r="6" />
                <path d="m16 16 4 4" />
            </svg>
            <span>Search chats</span>
        </a>
        <a asp-controller="Chat" asp-action="Index" class="chat-nav-action">
            <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                <path d="M5 5v14" />
                <path d="M9 5v14" />
                <path d="M13 7v12" />
                <path d="m17 7 2 12" />
            </svg>
            <span>Library</span>
        </a>
    </nav>

    <div class="chat-sidebar-list" aria-label="Conversations">
        @if (!conversations.Any())
        {
            <div class="chat-sidebar-empty">
                Chưa có cuộc trò chuyện nào.
            </div>
        }
        else
        {
            @foreach (var group in grouped)
            {
                <section class="chat-sidebar-group" aria-label="@group.Key">
                    <h2>@group.Key</h2>
                    <div class="chat-sidebar-items">
                        @foreach (var conversation in group)
                        {
                            var isActive = activeConversationId == conversation.Id;
                            <a asp-controller="Chat"
                               asp-action="Conversation"
                               asp-route-id="@conversation.Id"
                               class="chat-sidebar-item @(isActive ? "active" : "")">
                                @conversation.Title
                            </a>
                        }
                    </div>
                </section>
            }
        }
    </div>

    <footer class="chat-sidebar-user">
        <div class="chat-user-avatar">@initial</div>
        <div class="chat-user-copy">
            <strong>@userName</strong>
            <span>Student</span>
        </div>
        <form asp-controller="Account" asp-action="Logout" method="post" class="chat-user-logout">
            @Html.AntiForgeryToken()
            <button type="submit" title="Logout" aria-label="Logout">
                <svg viewBox="0 0 24 24" focusable="false" aria-hidden="true">
                    <path d="M10 6H6.5A2.5 2.5 0 0 0 4 8.5v7A2.5 2.5 0 0 0 6.5 18H10" />
                    <path d="M15 8l4 4-4 4" />
                    <path d="M9 12h10" />
                </svg>
            </button>
        </form>
    </footer>
</aside>
