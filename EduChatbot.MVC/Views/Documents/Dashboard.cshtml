@model EduChatbot.Models.DocumentDashboardSummary

@{
    ViewData["Title"] = "Dashboard";
}

<div class="page-header d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3 mb-3">
    <div>
        <h1 class="h4 mb-1">Document Dashboard</h1>
        <p class="text-muted mb-0">Academic documents indexed for RAG.</p>
    </div>
    <a asp-controller="Documents" asp-action="Upload" class="btn btn-primary">Upload document</a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4 col-lg">
        <div class="metric-card">
            <div class="metric-label">Total documents</div>
            <div class="metric-value">@Model.TotalDocuments</div>
        </div>
    </div>
    <div class="col-md-4 col-lg">
        <div class="metric-card">
            <div class="metric-label">Ready documents</div>
            <div class="metric-value text-success">@Model.ReadyDocuments</div>
        </div>
    </div>
    <div class="col-md-4 col-lg">
        <div class="metric-card">
            <div class="metric-label">Processing</div>
            <div class="metric-value text-warning">@Model.ProcessingDocuments</div>
        </div>
    </div>
    <div class="col-md-4 col-lg">
        <div class="metric-card">
            <div class="metric-label">Failed</div>
            <div class="metric-value text-danger">@Model.FailedDocuments</div>
        </div>
    </div>
    <div class="col-md-4 col-lg">
        <div class="metric-card">
            <div class="metric-label">Total chunks</div>
            <div class="metric-value">@Model.TotalChunks</div>
        </div>
    </div>
</div>

<div class="surface p-3">
    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center gap-3">
        <div>
            <h2 class="h6 mb-1">Document management</h2>
            <p class="text-muted mb-0">Review indexed documents and chunk data.</p>
        </div>
        <a asp-controller="Documents" asp-action="Index" class="btn btn-outline-primary">View documents</a>
    </div>
</div>
