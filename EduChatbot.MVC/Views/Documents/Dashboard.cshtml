@model EduChatbot.Models.DocumentDashboardSummary

@{
    ViewData["Title"] = "Dashboard";
}

<section class="role-page">
    <header class="role-hero">
        <div>
            <div class="role-kicker">Lecturer workspace</div>
            <h1>Document dashboard</h1>
            <p>Academic documents indexed for retrieval augmented generation.</p>
        </div>
        <a asp-controller="Documents" asp-action="Upload" class="role-primary-btn">Upload document</a>
    </header>

    <div class="role-stat-grid">
        <article class="role-stat-card">
            <span>Total documents</span>
            <strong>@Model.TotalDocuments</strong>
        </article>
        <article class="role-stat-card success">
            <span>Approved documents</span>
            <strong>@Model.ReadyDocuments</strong>
        </article>
        <article class="role-stat-card warning">
            <span>Pending review</span>
            <strong>@Model.ProcessingDocuments</strong>
        </article>
        <article class="role-stat-card danger">
            <span>Rejected/Failed</span>
            <strong>@Model.FailedDocuments</strong>
        </article>
        <article class="role-stat-card accent">
            <span>Total chunks</span>
            <strong>@Model.TotalChunks</strong>
        </article>
    </div>

    <div class="role-action-grid">
        <article class="role-panel role-panel-large">
            <div class="role-panel-label">Management</div>
            <h2>Review indexed materials</h2>
            <p data-i18n="docs.dashboard.viewFull">View complete list, check chunk data, and manage uploaded academic materials.</p>
            <a asp-controller="Documents" asp-action="Index" class="role-secondary-btn">View documents</a>
        </article>

        <a asp-controller="Documents" asp-action="Upload" class="role-upload-callout">
            <span>Upload</span>
            <strong data-i18n="docs.dashboard.addNew">Add new document</strong>
            <small data-i18n="docs.dashboard.fileFormats">PDF, DOCX, maximum 10 MB</small>
        </a>
    </div>
</section>
