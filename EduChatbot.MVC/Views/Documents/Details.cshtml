@model EduChatbot.Models.Document

@{
    ViewData["Title"] = "Document Details";
}

<section class="role-page">
    <header class="role-hero compact">
        <div>
            <div class="role-kicker">Document</div>
            <h1>@Model.FileName</h1>
            <p>Chunk details and real embedding preview.</p>
        </div>
        <div class="role-header-actions">
            <a asp-controller="Documents" asp-action="Index" class="role-secondary-btn">Back</a>
            <a asp-controller="Documents" asp-action="Edit" asp-route-id="@Model.Id" class="role-secondary-btn">Edit</a>
            <a href="@Model.FilePath" target="_blank" class="role-primary-btn">Open file</a>
        </div>
    </header>

    @if (TempData["UploadMessage"] != null)
    {
        <div class="role-alert success"><strong>@TempData["UploadMessage"]</strong></div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="role-alert danger">@TempData["ErrorMessage"]</div>
    }

    <div class="role-info-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 1rem;">
        <article>
            <span>Status</span>
            <strong style="color: @(Model.Status == EduChatbot.Models.DocumentStatuses.Approved ? "var(--edu-success)" : Model.Status == EduChatbot.Models.DocumentStatuses.Rejected ? "var(--edu-danger)" : "inherit")">@Model.Status</strong>
        </article>
        <article>
            <span>Môn học</span>
            <strong>@(!string.IsNullOrWhiteSpace(Model.SubjectCode) ? $"[{Model.SubjectCode}] {Model.SubjectName}" : Model.Course != null ? $"[{Model.Course.Code}] {Model.Course.Name}" : "N/A")</strong>
        </article>
        <article>
            <span>Match Score</span>
            <strong>@(Model.MatchScore.HasValue ? Model.MatchScore.Value.ToString("0.00") : "N/A")</strong>
        </article>
        <article>
            <span>Chunks</span>
            <strong>@Model.ChunkCount</strong>
        </article>
        <article>
            <span>Lecturer</span>
            <strong>@Model.UploadedBy</strong>
        </article>
        <article>
            <span>Uploaded</span>
            <strong>@Model.UploadedAt.ToString("dd/MM/yyyy HH:mm")</strong>
        </article>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.ValidationResult))
    {
        var isRejected = Model.Status == EduChatbot.Models.DocumentStatuses.Rejected;
        <div class="role-alert" style="margin-top: 1.5rem; padding: 1.2rem; border-radius: 8px; border-left: 5px solid @(isRejected ? "var(--edu-danger)" : "var(--edu-success)"); background: @(isRejected ? "rgba(255, 154, 162, 0.08)" : "rgba(168, 230, 207, 0.08)"); color: var(--edu-text);">
            <h4 style="margin-top: 0; font-size: 1.1rem; font-weight: 600; margin-bottom: 0.5rem; display: flex; align-items: center; gap: 0.5rem; color: @(isRejected ? "var(--edu-danger)" : "var(--edu-success)");">
                <span>Similarity</span> Kết quả Match Score:
            </h4>
            <p style="margin: 0; font-size: 0.95rem; line-height: 1.6; white-space: pre-line;">@Model.ValidationResult</p>
        </div>
    }

    @if (!Model.Chunks.Any())
    {
        <div class="role-alert warning">Document này chưa có chunk data.</div>
    }
    else
    {
        <div class="role-table-card">
            <div class="role-table-toolbar">Chunks and embeddings</div>
            <div class="table-responsive">
                <table class="table role-table role-chunk-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Index</th>
                            <th>Content</th>
                            <th>Embedding preview</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var chunk in Model.Chunks)
                        {
                            <tr>
                                <td><span class="role-chunk-index">@chunk.ChunkIndex</span></td>
                                <td>@chunk.Content</td>
                                <td>
                                    @{
                                        var embeddingPreview = chunk.Embedding == null
                                            ? "No embedding"
                                            : string.Join(", ", chunk.Embedding.ToArray().Take(8).Select(value => value.ToString("0.0000"))) + " ...";
                                    }
                                    <code>@embeddingPreview</code>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</section>
