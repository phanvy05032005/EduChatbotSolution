@model EduChatbot.MVC.Models.RegisterViewModel

@{
    ViewData["Title"] = "Register";
    Layout = "_AuthLayout";
}

<div class="auth-container">
    <!-- LEFT — Branding Panel -->
    <aside class="auth-branding">
        <div class="auth-logo">
            <div class="auth-logo-icon">🎓</div>
            <div>
                <div class="auth-logo-text">EduChatbot</div>
                <div class="auth-logo-sub">Academic assistant</div>
            </div>
        </div>

        <div class="auth-branding-content">
            <div class="auth-badge">
                ✦ <span>Join the platform</span>
            </div>
            <h1 class="auth-headline">
                Học tập <em>thông minh</em><br />
                cùng tài liệu của bạn.
            </h1>
            <p class="auth-tagline">
                Hỏi đáp tức thì về tài liệu giảng viên đã upload — kèm trích dẫn nguồn rõ ràng theo từng đoạn.
            </p>

            <div class="auth-features">
                <div class="auth-feature-card">
                    <div class="auth-feature-icon">📖</div>
                    <div class="auth-feature-label">Tài liệu</div>
                </div>
                <div class="auth-feature-card">
                    <div class="auth-feature-icon">💬</div>
                    <div class="auth-feature-label">Hỏi đáp</div>
                </div>
                <div class="auth-feature-card">
                    <div class="auth-feature-icon">✦</div>
                    <div class="auth-feature-label">Trích nguồn</div>
                </div>
            </div>
        </div>

        <div class="auth-copyright">© 2026 EduChatbot · Academic platform</div>
    </aside>

    <!-- RIGHT — Form Panel -->
    <section class="auth-form-panel">
        <div class="auth-form-wrapper">
            <!-- Mobile logo -->
            <div class="auth-mobile-logo">
                <div class="auth-logo-icon">🎓</div>
                <div class="auth-logo-text">EduChatbot</div>
            </div>

            <!-- Tab switcher -->
            <div class="auth-tabs">
                <a asp-controller="Account" asp-action="Login" class="auth-tab">Login</a>
                <span class="auth-tab active">Register</span>
            </div>

            <h2 class="auth-form-title">Tạo tài khoản <em>mới</em></h2>
            <p class="auth-form-subtitle">Create a Student or Lecturer account.</p>

            <form asp-controller="Account" asp-action="Register" method="post">
                @Html.AntiForgeryToken()

                <div asp-validation-summary="All" class="auth-errors"></div>

                <!-- Full Name -->
                <div class="auth-field">
                    <label asp-for="FullName" class="auth-field-label">Full Name</label>
                    <div class="auth-field-input-wrapper">
                        <span class="auth-field-icon">👤</span>
                        <input asp-for="FullName" placeholder="Nguyễn Văn A" />
                    </div>
                </div>

                <!-- Email -->
                <div class="auth-field">
                    <label asp-for="Email" class="auth-field-label">Email</label>
                    <div class="auth-field-input-wrapper">
                        <span class="auth-field-icon">✉</span>
                        <input asp-for="Email" placeholder="student@university.edu.vn" />
                    </div>
                </div>

                <!-- Password -->
                <div class="auth-field">
                    <label asp-for="Password" class="auth-field-label">Password</label>
                    <div class="auth-field-input-wrapper">
                        <span class="auth-field-icon">🔒</span>
                        <input asp-for="Password" placeholder="••••••••" />
                    </div>
                </div>

                <!-- Role -->
                <div class="auth-field">
                    <label asp-for="Role" class="auth-field-label">Role</label>
                    <div class="auth-field-input-wrapper">
                        <select asp-for="Role">
                            <option value="Student">Student</option>
                            <option value="Lecturer">Lecturer</option>
                        </select>
                        <span class="auth-select-arrow">▾</span>
                    </div>
                </div>

                <!-- Submit -->
                <button type="submit" class="auth-submit-btn">
                    <span>Create account</span>
                    <span class="arrow">→</span>
                </button>

                <!-- Divider -->
                <div class="auth-divider">
                    <div class="auth-divider-line"></div>
                    <span class="auth-divider-text">or</span>
                </div>

                <!-- Switch -->
                <div class="auth-switch">
                    Đã có tài khoản?
                    <a asp-controller="Account" asp-action="Login">Sign in</a>
                </div>
            </form>
        </div>
    </section>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
