@model List<EduChatbot.Models.Document>

@{
    ViewData["Title"] = "Pending Document Review";
}

<div class="admin-page">
    <div class="admin-page-header">
        <div>
            <div class="admin-kicker">Documents</div>
            <h1>Pending <span class="admin-serif">Review</span></h1>
            <p>Review documents whose subject match score is below the automatic approval threshold.</p>
        </div>
    </div>

    @if (TempData["AdminMessage"] != null)
    {
        <div class="admin-alert success">@TempData["AdminMessage"]</div>
    }

    @if (TempData["AdminError"] != null)
    {
        <div class="admin-alert danger">@TempData["AdminError"]</div>
    }

    @if (!Model.Any())
    {
        <section class="admin-card" style="padding:1.5rem;">
            <strong>No documents are waiting for review.</strong>
        </section>
    }
    else
    {
        <section class="admin-card admin-table-card">
            <div class="admin-card-header">
                <h2>Documents waiting for admin decision</h2>
                <span>@Model.Count pending</span>
            </div>
            <div class="table-responsive">
                <table class="table admin-table mb-0">
                    <thead>
                        <tr>
                            <th>File Name</th>
                            <th>Lecturer</th>
                            <th>Subject</th>
                            <th>Match Score</th>
                            <th>Upload Date</th>
                            <th>Reason</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var document in Model)
                        {
                            <tr>
                                <td><strong>@document.FileName</strong></td>
                                <td>@document.UploadedBy</td>
                                <td>[@document.SubjectCode] @document.SubjectName</td>
                                <td>@((document.MatchScore ?? 0).ToString("0.00"))</td>
                                <td>@document.UploadedAt.ToString("dd/MM/yyyy HH:mm")</td>
                                <td style="max-width:260px;">@document.ValidationResult</td>
                                <td>
                                    <div style="display:flex; gap:0.5rem; flex-wrap:wrap;">
                                        <form asp-controller="Admin" asp-action="ApproveDocument" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@document.Id" />
                                            <button type="submit" class="admin-primary-btn">Approve</button>
                                        </form>
                                        <form asp-controller="Admin" asp-action="RejectDocument" method="post">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@document.Id" />
                                            <input type="hidden" name="reviewNote" value="Rejected by admin." />
                                            <button type="submit" class="danger" style="background:none; border:none; color:var(--admin-danger); cursor:pointer;">Reject</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </section>
    }
</div>
