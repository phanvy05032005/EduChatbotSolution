@model List<EduChatbot.MVC.Models.UserListItemViewModel>

@{
    ViewData["Title"] = "Users";
}

<div class="page-header d-flex justify-content-between align-items-center mb-3">
    <div>
        <h1 class="h4 mb-1">Users</h1>
        <p class="text-muted mb-0">Admin account overview.</p>
    </div>
</div>

<div class="surface p-0">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Email</th>
                    <th>Full name</th>
                    <th>Roles</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Email</td>
                        <td>@item.FullName</td>
                        <td>@item.Roles</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
