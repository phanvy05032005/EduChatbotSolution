@model EduChatbot.MVC.Models.AdminStatisticsViewModel

@{
    ViewData["Title"] = "Statistics";
    var items = new[]
    {
        new { Label = "Total Students", Value = Model.TotalStudents, Tone = "success" },
        new { Label = "Total Lecturers", Value = Model.TotalLecturers, Tone = "accent" },
        new { Label = "Total Documents", Value = Model.TotalDocuments, Tone = "light" },
        new { Label = "Total Questions Asked", Value = Model.TotalQuestionsAsked, Tone = "warning" }
    };
    var topics = new[]
    {
        new { Name = "ASP.NET", Value = Math.Max(Model.TotalQuestionsAsked, 1) },
        new { Name = "EF Core", Value = Math.Max(Model.TotalDocuments, 1) },
        new { Name = "MVC", Value = Math.Max(Model.TotalLecturers, 1) },
        new { Name = "SQL", Value = Math.Max(Model.TotalStudents, 1) }
    };
}

<div class="admin-page">
    <div class="admin-page-header">
        <div>
            <div class="admin-kicker" data-i18n="admin.sidebar.statistics">Analytics</div>
            <h1><span data-i18n="admin.stats.title">System</span> <span class="admin-serif" data-i18n="admin.stats.titleSerif">Statistics</span></h1>
            <p data-i18n="admin.stats.subtitle">Usage activity and overall data trends.</p>
        </div>
    </div>

    <section class="admin-card admin-stat-chart">
        <div class="admin-card-header">
            <h2 data-i18n="admin.stats.totals">System Totals</h2>
            <span data-i18n="admin.stats.snapshot">Current snapshot</span>
        </div>
        <div class="simple-chart">
            @foreach (var item in items)
            {
                var width = Math.Max(8, item.Value * 100 / Model.MaxValue);
                var labelKey = item.Label switch
                {
                    "Total Students" => "admin.dashboard.totalStudents",
                    "Total Lecturers" => "admin.dashboard.totalLecturers",
                    "Total Documents" => "admin.stats.totalDocuments",
                    "Total Questions Asked" => "admin.stats.totalQuestionsAsked",
                    _ => ""
                };
                <div class="chart-row @item.Tone">
                    <label data-i18n="@labelKey">@item.Label</label>
                    <div class="chart-track">
                        <div class="chart-bar" style="width: @(width)%"></div>
                    </div>
                    <strong>@item.Value.ToString("N0")</strong>
                </div>
            }
        </div>
    </section>

    <section class="admin-card admin-stat-chart mt-3">
        <div class="admin-card-header">
            <h2 data-i18n="admin.stats.topTopics">Top topics</h2>
            <span data-i18n="admin.stats.relativeActivity">Relative activity</span>
        </div>
        <div class="topic-bars">
            @foreach (var topic in topics)
            {
                var width = Math.Max(8, topic.Value * 100 / topics.Max(t => t.Value));
                <div class="topic-row">
                    <span>@topic.Name</span>
                    <div class="chart-track">
                        <div class="chart-bar" style="width: @(width)%"></div>
                    </div>
                    <strong>@topic.Value</strong>
                </div>
            }
        </div>
    </section>
</div>
