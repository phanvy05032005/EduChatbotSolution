@model EduChatbot.MVC.Models.AdminAccountFormViewModel

@{
    ViewData["Title"] = Model.IsEdit ? "Edit Account" : $"Create {Model.AccountType} Account";
    var formAction = Model.IsEdit ? "EditAccount" : "CreateAccount";
    var returnAction = Model.AccountType == EduChatbot.Models.Identity.ApplicationRoles.Lecturer
        ? "Lecturers"
        : "Students";
}

<div class="admin-page admin-page-narrow">
    <div class="admin-page-header">
        <div>
            <div class="admin-kicker">Accounts · @Model.AccountType</div>
            <h1>@(Model.IsEdit ? "Chỉnh sửa" : "Tạo mới") <span class="admin-serif">tài khoản</span></h1>
            <p>Maintain @Model.AccountType.ToLowerInvariant() identity information.</p>
        </div>
    </div>

    <form asp-controller="Admin" asp-action="@formAction" method="post" class="admin-card admin-form">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <input asp-for="AccountType" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="admin-form-errors"></div>

        <div class="admin-field">
            <label asp-for="FullName">Full Name</label>
            <input asp-for="FullName" maxlength="100" />
            <span asp-validation-for="FullName" class="admin-validation"></span>
        </div>

        <div class="admin-field">
            <label asp-for="Email">Email</label>
            <input asp-for="Email" />
            <span asp-validation-for="Email" class="admin-validation"></span>
        </div>

        @if (!Model.IsEdit)
        {
            <div class="admin-field">
                <label asp-for="Password">Password</label>
                <input asp-for="Password" />
                <span asp-validation-for="Password" class="admin-validation"></span>
            </div>

            <div class="admin-field" style="display: flex; align-items: center; gap: 0.5rem; margin-top: 0.5rem;">
                <input asp-for="SendEmail" type="checkbox" id="SendEmail" style="width: auto; min-height: auto; cursor: pointer;" />
                <label for="SendEmail" style="margin-bottom: 0; cursor: pointer; text-transform: none; letter-spacing: normal; font-weight: 500;">Gửi email thông báo tài khoản</label>
            </div>
        }

        <div class="admin-form-actions">
            <button type="submit" class="admin-primary-btn">Save Account</button>
            <a asp-controller="Admin"
               asp-action="@returnAction"
               class="admin-secondary-btn">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
