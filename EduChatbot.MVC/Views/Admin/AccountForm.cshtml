@model EduChatbot.MVC.Models.AdminAccountFormViewModel

@{
    ViewData["Title"] = Model.IsEdit ? "Edit Account" : $"Create {Model.AccountType} Account";
    var formAction = Model.IsEdit ? "EditAccount" : "CreateAccount";
    var returnAction = Model.AccountType == EduChatbot.Models.Identity.ApplicationRoles.Lecturer
        ? "Lecturers"
        : "Students";
}

<div class="admin-page admin-page-narrow">
    <div class="admin-page-header">
        <div>
            <div class="admin-kicker"><span data-i18n="admin.accounts.accounts">Accounts</span> · @Model.AccountType</div>
            <h1><span data-i18n="@(Model.IsEdit ? "admin.form.edit" : "admin.form.create")">@(Model.IsEdit ? "Edit" : "Create")</span> <span class="admin-serif" data-i18n="admin.form.account">Account</span></h1>
            <p data-i18n="admin.form.maintainDesc">Maintain @Model.AccountType.ToLowerInvariant() identity information.</p>
        </div>
    </div>

    <form asp-controller="Admin" asp-action="@formAction" method="post" class="admin-card admin-form">
        @Html.AntiForgeryToken()
        <input asp-for="Id" type="hidden" />
        <input asp-for="AccountType" type="hidden" />

        <div asp-validation-summary="ModelOnly" class="admin-form-errors"></div>

        <div class="admin-field">
            <label asp-for="FullName" data-i18n="admin.form.fullName">Full Name</label>
            <input asp-for="FullName" maxlength="100" />
            <span asp-validation-for="FullName" class="admin-validation"></span>
        </div>

        <div class="admin-field">
            <label asp-for="Email" data-i18n="admin.accounts.email">Email</label>
            <input asp-for="Email" />
            <span asp-validation-for="Email" class="admin-validation"></span>
        </div>

        @if (!Model.IsEdit)
        {
            <div class="admin-field">
                <label asp-for="Password" data-i18n="admin.form.password">Password</label>
                <input asp-for="Password" />
                <span asp-validation-for="Password" class="admin-validation"></span>
            </div>

            @if (Model.AccountType == EduChatbot.Models.Identity.ApplicationRoles.Lecturer)
            {
                <div class="admin-field">
                    <label data-i18n="admin.form.assignedCourses">Assigned Courses</label>

                    <input id="courseSearch" type="search" placeholder="Search by code or name (e.g. PRN222, .NET...)"
                           data-i18n-placeholder="admin.form.searchCourses"
                           style="min-height: 44px; border: 1px solid rgba(228, 240, 246, 0.12); border-radius: 12px; outline: 0; background: rgba(228, 240, 246, 0.04); color: #e4f0f6; font: inherit; padding: 0.65rem 0.9rem;" />

                    <select id="courseSelect" name="SelectedCourseIds" multiple size="8"
                            style="width: 100%; border: 1px solid rgba(228, 240, 246, 0.12); border-radius: 12px; background: rgba(228, 240, 246, 0.04); color: #e4f0f6; font: inherit; padding: 0.6rem 0.75rem;">
                        @if (Model.AvailableCourses.Count == 0)
                        {
                            <option value="" disabled data-i18n="admin.form.noCourses">No courses available. Please create courses first.</option>
                        }
                        else
                        {
                            @foreach (var course in Model.AvailableCourses)
                            {
                                <option value="@course.Id" data-search="@(course.Code + " " + course.Name)">[@course.Code] - @course.Name</option>
                            }
                        }
                    </select>

                    <div style="color: rgba(228, 240, 246, 0.65); font-size: 0.85rem;" data-i18n="admin.form.holdToSelect">
                        Hold Cmd (macOS) / Ctrl (Windows) to select multiple courses.
                    </div>
                </div>
            }

            <p style="margin: 0.5rem 0 0; color: rgba(228, 240, 246, 0.68); font-size: 0.9rem;" data-i18n="admin.form.autoSendEmail">
                The system will automatically send account credentials to the user's email after successful creation.
            </p>
        }

        <div class="admin-form-actions">
            <button type="submit" class="admin-primary-btn" data-i18n="admin.form.save">Save Account</button>
            <a asp-controller="Admin"
               asp-action="@returnAction"
               class="admin-secondary-btn" data-i18n="admin.form.cancel">Cancel</a>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        (function () {
            const searchInput = document.getElementById('courseSearch');
            const courseSelect = document.getElementById('courseSelect');
            if (!searchInput || !courseSelect) return;

            const normalize = (value) => (value || '').toString().toLowerCase().trim();

            searchInput.addEventListener('input', function () {
                const q = normalize(searchInput.value);
                const options = Array.from(courseSelect.options);

                options.forEach(opt => {
                    const haystack = normalize(opt.getAttribute('data-search') || opt.text);
                    // disabled option message: always visible
                    if (opt.disabled) {
                        opt.hidden = false;
                        return;
                    }
                    opt.hidden = q.length > 0 && !haystack.includes(q);
                });
            });
        })();
    </script>
}
