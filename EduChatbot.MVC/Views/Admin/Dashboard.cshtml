@model EduChatbot.MVC.Models.AdminDashboardViewModel

@{
    ViewData["Title"] = "Dashboard";
    var metrics = new[]
    {
        new { Label = "Total Students", Value = Model.TotalStudents, Delta = "+12.4%", Tone = "success", Icon = "♙" },
        new { Label = "Total Lecturers", Value = Model.TotalLecturers, Delta = "+2", Tone = "accent", Icon = "♧" },
        new { Label = "Documents in System", Value = Model.TotalDocuments, Delta = "+18", Tone = "light", Icon = "▤" },
        new { Label = "Total Chat Questions", Value = Model.TotalChatQuestions, Delta = "+342", Tone = "warning", Icon = "▢" }
    };
    var chartPoints = new[] { 38, 46, 43, 58, 70, 78, 74 };
}

<div class="admin-page">
    <div class="admin-page-header">
        <div>
            <div class="admin-kicker" data-i18n="admin.dashboard.kicker">System overview</div>
            <h1><span data-i18n="admin.dashboard.title">System</span> <span class="admin-serif" data-i18n="admin.dashboard.titleSerif">Overview</span></h1>
            <p data-i18n="admin.dashboard.subtitle">Monitor metrics and activity across the EduChatbot system.</p>
        </div>
        <a asp-controller="Admin" asp-action="Dashboard" class="admin-secondary-btn" data-i18n="admin.dashboard.refresh">Refresh</a>
    </div>

    <div class="admin-metric-grid">
        @foreach (var metric in metrics)
        {
            var metricKey = metric.Label switch
            {
                "Total Students" => "admin.dashboard.totalStudents",
                "Total Lecturers" => "admin.dashboard.totalLecturers",
                "Documents in System" => "admin.dashboard.documentsInSystem",
                "Total Chat Questions" => "admin.dashboard.totalChatQuestions",
                _ => ""
            };
            <article class="admin-card admin-metric-card @metric.Tone">
                <div class="admin-card-glow"></div>
                <div class="admin-metric-top">
                    <span class="admin-metric-icon">@metric.Icon</span>
                    <span class="admin-delta">@metric.Delta</span>
                </div>
                <strong>@metric.Value.ToString("N0")</strong>
                <span data-i18n="@metricKey">@metric.Label</span>
            </article>
        }
    </div>

    <div class="admin-dashboard-grid">
        <section class="admin-card admin-activity-card">
            <div class="admin-card-header">
                <h2><span aria-hidden="true">⌁</span> <span data-i18n="admin.dashboard.recentActivities">Recent activities</span></h2>
                <span class="admin-live-pill" data-i18n="admin.dashboard.live">Live</span>
            </div>
            <ul class="activity-list">
                @foreach (var activity in Model.RecentActivities)
                {
                    <li>
                        <span class="activity-icon" aria-hidden="true">✦</span>
                        <div>
                            <strong>@activity</strong>
                            <small data-i18n="admin.dashboard.updatedJustNow">Updated just now · Admin</small>
                        </div>
                    </li>
                }
            </ul>
        </section>

        <aside class="admin-card admin-sparkline-card">
            <div class="admin-chart-title" data-i18n="admin.dashboard.questionsLast7">Questions · last 7 days</div>
            <div class="admin-sparkline" aria-hidden="true">
                @foreach (var point in chartPoints)
                {
                    <span style="height:@point%"></span>
                }
            </div>
            <div class="admin-chart-total">
                <div>
                    <strong>@Math.Max(Model.TotalChatQuestions, 0).ToString("N0")</strong>
                    <span data-i18n="admin.dashboard.totalQuestions">Total questions</span>
                </div>
                <em>+18.2%</em>
            </div>
        </aside>
    </div>
</div>
